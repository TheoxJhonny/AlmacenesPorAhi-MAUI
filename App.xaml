<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhiMaui.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Bg">#101826</Color>
            <Color x:Key="Panel">#172235</Color>
            <Color x:Key="Panel2">#20304A</Color>
            <Color x:Key="Accent">#35D0BA</Color>
            <Color x:Key="Accent2">#7C5CFF</Color>
            <Color x:Key="TextMain">#F4F7FB</Color>
            <Color x:Key="TextMuted">#A9B7CC</Color>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="#F4F7FB" />
            </Style>
            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="PlaceholderColor" Value="#94A3B8" />
                <Setter Property="BackgroundColor" Value="#22314A" />
            </Style>
            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="White" />
                <Setter Property="TitleColor" Value="#94A3B8" />
                <Setter Property="BackgroundColor" Value="#22314A" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="BackgroundColor" Value="#35D0BA" />
                <Setter Property="TextColor" Value="#071318" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
